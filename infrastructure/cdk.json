{
  "app": "npx ts-node lib/app.ts",
  "watch": {
    "include": ["lib/**"],
    "exclude": ["cdk.out", "node_modules", "dist"]
  },
  "context": {
    "@aws-cdk/core:enableStackNameDuplicates": true,
    "availability-zones:account=123456789012:region=ap-southeast-1": [
      "ap-southeast-1a",
      "ap-southeast-1b",
      "ap-southeast-1c"
    ]
  }
}
